  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fusiontechsolution-ai/eks-tunnel.git"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^9.3.7"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.10",
    "@types/node": "^20.14.0",
    "fast-check": "^3.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
