{
  "name": "@fusiontechsolution.ai/eks-tunnel",
  "version": "0.1.2",
  "description": "CLI tool to establish SSM port-forwarding tunnels to private EKS clusters through bastion hosts",
  "main": "./dist/cli.js",
  "bin": {
    "eks-tunnel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:property": "vitest run tests/property"
  },
  "engines": {
